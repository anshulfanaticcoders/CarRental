# Social Auth (web OAuth via Socialite)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
FACEBOOK_REDIRECT_URI=

# Apple Sign-In (native, mobile app) — iOS bundle identifier, used as the
# expected `aud` claim when verifying the Apple identity token.
APPLE_CLIENT_ID=

# Admin recipient for booking / review / vendor notifications. MUST match a
# real users.email row, otherwise admin notifications are silently dropped.
VITE_ADMIN_EMAIL=

# Stripe — public + secret keys + webhook signing secret. webhook_secret is the
# value Stripe shows in dashboard → Developers → Webhooks → reveal signing secret.
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Mailtrap — transactional email production API (Sending), and sandbox API for
# tests. MAIL_HOST etc. fall back to SMTP when API key absent.
MAILTRAP_API_KEY=
MAILTRAP_SANDBOX=false

# Provider markup applied to all gateway / internal vehicles (0.15 = 15%).
# Read by StripeCheckoutController + HandleInertiaRequests + GatewayVehicleTransformer.
PROVIDER_MARKUP_PERCENT=0.15

# Cloudflare Turnstile (contact form CAPTCHA)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Stadia Maps API key — used by GeocodingController for reverse geocoding +
# geocode lookups in the admin dashboard map widgets.
VITE_STADIA_MAPS_API_KEY=

# Exchange rate API for currency conversion (RefreshCurrencyRates command)
EXCHANGERATE_API_KEY=

# eSIM Access provider (free eSIM offer for some bookings)
ESIM_ACCESS_API_KEY=
ESIM_ACCESS_API_URL=

# RecordRentacar provider (Record Go) — legacy external supplier
RECORDRENTACAR_SUBSCRIPTION_KEY=
RECORDRENTACAR_SELLCODE_DEFAULT=
RECORDRENTACAR_SELLCODE_ES=
RECORDRENTACAR_SELLCODE_IT=
RECORDRENTACAR_SELLCODE_PT=

# Vrooem Gateway — internal FastAPI service. URL + API key for service-to-service auth.
VROOEM_GATEWAY_BASE_URL=http://localhost:8001
VROOEM_GATEWAY_API_KEY=
VROOEM_ENABLED=true
